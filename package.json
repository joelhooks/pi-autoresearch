{
  "name": "pi-autoresearch",
  "version": "0.1.0",
  "description": "Karpathy-style autonomous research loops for pi: propose, run, score, keep or revert experiments.",
  "type": "module",
  "bin": {
    "pi-autoresearch": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "PRIOR_ART.md",
    "EXTENSION_DEV.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "check": "bun test && tsc -p tsconfig.json"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "autoresearch",
    "agents",
    "research",
    "experiments",
    "metric-gated"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.33"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "~0.52.12"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "author": "Joel Hooks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelhooks/pi-autoresearch.git"
  },
  "bugs": {
    "url": "https://github.com/joelhooks/pi-autoresearch/issues"
  },
  "homepage": "https://github.com/joelhooks/pi-autoresearch#readme",
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  }
}
